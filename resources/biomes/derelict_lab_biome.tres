[gd_resource type="Resource" script_class="BiomeProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/biome_profile.gd" id="1"]

[resource]
script = ExtResource("1")
biome_id = &"derelict_lab"
display_name = "Derelict Lab"
description = "Dark maintenance decks powered by failing aux generators. Emergency strobes fight against cold ambient fill."
